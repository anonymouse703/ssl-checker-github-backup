# PageSpeed Insights API Key
PAGESPEED_API_KEY=AIzaSyBiZlF6vaADX2vj5C-c2nRBWOqkwrczDng

# PageRankAPI Key
PAGERANK_API_KEY=o8go8s8004kso8g8wsg44go4ggss40wocksw4coo

# Tool Config
PORT=3000
TOOL_DIR=/usr/local/ind_leads/ssl-checker-tool
OUTPUT_DIR=/home/ind/ind_leads_inputs
SCAN_ROOT=/home/ind

# Remote image sync
IMAGE_SYNC_ENABLED=true
IMAGE_SYNC_HOST=ta1.in-depth.com
IMAGE_SYNC_USER=ind
IMAGE_SYNC_BASE_DIR=/home/ta1/public_html/images
IMAGE_SYNC_SSH_KEY=/home/ind/.ssh/id_rsa
IMAGE_SYNC_SSH_PORT=44781
IMAGE_SYNC_SUDO=true
IMAGE_SYNC_BASE_URL=https://ta1.in-depth.com/images

# Browser Pool
BROWSER_POOL_SIZE=3
BROWSER_POOL_TIMEOUT_MS=600000
BROWSER_IDLE_TIMEOUT_MS=300000

# Stale job cleanup
STALE_JOB_MAX_AGE_HOURS=2

# Puppeteer Chrome path
PUPPETEER_EXECUTABLE_PATH=/usr/local/ind_leads/ssl-checker-tool/chrome/linux-146.0.7680.76/chrome-linux64/chrome

# Batching
BATCH_MODE=true

# Memory / concurrency — these control each spawned child, not the queue depth.
# With MINUTES_GAP > 0, MAX_CONCURRENT is overridden to 1 inside multi-audit.js.
MEMORY_LIMIT_MB=1000

# Node memory per child process
NODE_OPTIONS=--max-old-space-size=256

# Stable scan mode
MAX_CONCURRENT=3
BROWSER_POOL_SIZE=1
TOOL_RUN_MODE=sequential

# Domain hard timeout for all tools in sequential mode
DOMAIN_HARD_TIMEOUT_MS=5400000

# Image sync safety
IMAGE_SYNC_TIMEOUT_MS=120000
IMAGE_SYNC_COMMAND_TIMEOUT_MS=120000
IMAGE_SYNC_CONNECT_TIMEOUT_SEC=20
IMAGE_SYNC_RSYNC_IO_TIMEOUT_SEC=60
MULTI_AUDIT_POST_SYNC_ENABLED=false

# Keep monitor/result files longer
PERIODIC_CLEANUP_HOURS=24

# SSL Labs correct timeout names
SSL_TIMEOUT_MS=1800000
SSL_ATTEMPTS=1
SSL_LABS_BROWSER_MAX_WAIT_MS=900000
SSL_LABS_FIRST_GRADE_MAX_WAIT_MS=720000
SSL_LABS_ALL_DONE_MAX_WAIT_MS=1500000

# Pingdom
PINGDOM_TIMEOUT_MS=1980000
PINGDOM_RESULT_MAX_WAIT_MS=480000
PINGDOM_STABLE_METRICS_WAIT_MS=120000
PINGDOM_MAX_RETRIES=3
PINGDOM_ENABLE_OUTER_REQUIRED_RETRY=0
PINGDOM_REQUIRED_DATA_ATTEMPTS=1
PINGDOM_REQUIRED_DATA_DELAY_MS=10000
PINGDOM_USE_DEDICATED_BROWSER=true
PINGDOM_TOOLS_URLS=https://tools.pingdom.com/,https://tool.pingdom.com/
PINGDOM_LOCATION=North America - USA - San Francisco
PINGDOM_ATTEMPTS=3
PINGDOM_CAPTURE_LIVE_RESULTS=1
PINGDOM_LOCAL_SCREENSHOT_FALLBACK=1

#WordPress
WORDPRESS_DETECT_ENABLED=1

